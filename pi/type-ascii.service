[Unit]
Description=USB HID Keyboard Typer
After=sys-kernel-config.mount

[Service]
Type=simple
ExecStartPre=/usr/sbin/gadget-bind
ExecStart=/usr/sbin/type-ascii /run/kb-serve/kb.sock
ExecStopPost=/usr/sbin/gadget-unbind
RuntimeDirectory=kb-serve
RuntimeDirectoryMode=0755
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target
