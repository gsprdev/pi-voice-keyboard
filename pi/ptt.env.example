# Push-to-Talk Configuration
# Copy this file to /etc/default/ptt and edit with your values

# REQUIRED: Comma-separated list of transcription service URLs in preference order
# The first healthy server will be used; others serve as fallbacks
PTT_SERVICE_URLS=http://your-gpu-host.local:8080
# PTT_HEALTH_CHECK_INTERVAL=10
# PTT_HEALTH_CHECK_TIMEOUT=200
