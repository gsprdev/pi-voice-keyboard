# Push-to-Talk Configuration
# Copy this file to /etc/default/ptt and edit with your values

# REQUIRED: Comma-separated list of transcription service URLs (priority order)
# The first reachable server will be used. Use http:// for local network.
# Do not include trailing slash or endpoint path.
PTT_SERVICE_URLS=http://gpu1.local:8080,http://gpu2.local:8080

# Health check interval in seconds (default: 10)
#PTT_HEALTH_INTERVAL=10

# Per-server health check timeout in milliseconds (default: 200)
#PTT_HEALTH_TIMEOUT=200
