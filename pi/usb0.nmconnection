# USB Ethernet (CDC-ECM) — NetworkManager connection profile
#
# Subnet: 192.168.71.0/24
#   Pi address:   192.168.71.1
#   Host address:  192.168.71.2

[connection]
id=usb0
type=ethernet
interface-name=usb0
autoconnect=true

[ipv4]
method=manual
address1=192.168.71.1/24
route-metric=2000
never-default=true

[ipv6]
method=ignore
